# Переменные окружения для Amvera (задаются в интерфейсе проекта → Переменные)

BOT_TOKEN=your_telegram_bot_token
KIE_API_KEY=your_kie_api_key
REFERRAL_BOT_USERNAME=tarot_robobot
ADMIN_IDS=123456789

DASHBOARD_PASSWORD=change_me
DASHBOARD_SECRET=change-me-astorobot-dashboard

# Обычно менять не нужно — уже заданы в Dockerfile
LOCAL_DEV=false
DATABASE_URL=sqlite+aiosqlite:////data/astorobot.db
REDIS_URL=memory://local
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=80
PYTHONUNBUFFERED=1

TIMEZONE=Europe/Moscow
MORNING_DIGEST_HOUR=8
EVENING_DIGEST_HOUR=20
WEEKLY_HOROSCOPE_HOUR=9

PRIVACY_POLICY_URL=https://example.com/privacy
CONSENT_URL=https://example.com/consent
OFFER_URL=https://example.com/offer
